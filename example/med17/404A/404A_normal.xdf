  <XDFCONSTANT vislevel="10">
    <title>Cal checksum (EXPERT)</title>
    <description>Used to ensure that a cal .bin is compatible with Dyno Spectrum updates and between ECU software versions. After updating the DS1, it can be copied from a freshly downloaded stock or OTS .bin to an old OTS or custom .bin to allow it to be used as long as any new tables from the update are also populated and the ECU software matches. Incorrect use could result in an ECU that needs to be recovered on bench.</description>
    <CATEGORYMEM index="0" category="200" />
    <EMBEDDEDDATA mmedtypeflags="0x02" mmedaddress="0x98006C" mmedelementsizebits="32" mmedmajorstridebits="0" mmedminorstridebits="0" />
    <units>32 bit raw</units>
    <outputtype>3</outputtype>
    <decimalpl>0</decimalpl>
    <rangehigh>4294967296.000000</rangehigh>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="X">
      <VAR id="X" />
    </MATH>
  </XDFCONSTANT>
  <XDFCONSTANT vislevel="10">
    <title>Ethanol input pointer (EXPERT)</title>
    <description>Expert use only. Pointer to signed 16 bit value that is input to "Ethanol input to ethanol %". 16 bit alignment and address checking in code, but incorrect use will cause unpredictable results and possible need for ECU to be recovered on bench.</description>
